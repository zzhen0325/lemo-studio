# Curated runtime env example for local development and split frontend/backend deployment.
# Keep secrets on the backend. Do not expose secrets via NEXT_PUBLIC_*.
# Intentionally omitted here: runtime-injected host/port vars, debug-only flags,
# legacy fallback vars, and one-off script/test-only knobs.

# Frontend (Next.js)
# Same-origin proxy target used by Next route handlers and SSR.
GULUX_API_BASE=http://127.0.0.1:3000/api

# Leave empty to keep browser requests on same-origin /api.
# Only set when the browser must call the backend origin directly.
NEXT_PUBLIC_API_BASE=
NEXT_PUBLIC_APP_PORT=3001
NEXT_PUBLIC_SIDEBAR_MODE=full
NEXT_PUBLIC_COMFYUI_URL=
NEXT_IMAGE_ALLOWED_HOSTS=
NEXT_PUBLIC_ENABLE_TWEAKCN_LIVE_PREVIEW=false

# Optional absolute frontend origin for backend-side image fetching in split deployments.
NEXT_PUBLIC_BASE_URL=

# Backend required
# Production must provide a real Mongo URI.
MONGODB_URI=mongodb://127.0.0.1:27017/gulux
MONGODB_DB=gulux
API_CONFIG_ENCRYPTION_KEY=replace-with-a-strong-secret

# Only needed when the browser calls the backend origin directly.
CORS_ALLOW_ORIGINS=http://localhost:3001

# AI providers (backend only)
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-1-6-251015

GOOGLE_API_KEY=
GOOGLE_GENAI_API_KEY=
GOOGLE_TRANSLATE_API_KEY=

DEEPSEEK_API_KEY=

COZE_API_TOKEN=
COZE_PROMPT_API_TOKEN=
COZE_PROMPT_RUN_URL=https://m5385m4ryw.coze.site/run
COZE_SEED_API_TOKEN=
COZE_SEED_RUN_URL=https://2q3rqt6rnh.coze.site/run

# ByteDance AFR / Seed image generation
GATEWAY_BASE_URL=https://effect.bytedance.net
BYTEDANCE_AID=6834
BYTEDANCE_APP_KEY=
BYTEDANCE_APP_SECRET=

# ComfyUI and ViewComfy
COMFYUI_API_URL=
COMFYUI_SECURE=false
VIEW_COMFY_FILE_NAME=workflows/index.json
VIEWCOMFY_CLOUD_API_URL=
VIEWCOMFY_CLIENT_ID=
VIEWCOMFY_CLIENT_SECRET=
NEXT_PUBLIC_VIEWCOMFY_CLIENT_ID=
NEXT_PUBLIC_VIEWCOMFY_CLIENT_SECRET=

# Storage and CDN
DATASET_DIR=
CLOUD_STORAGE=local
CLOUD_PUBLIC_BASE=
CDN_BASE_URL=
CDN_DIR=
CDN_REGION=SG
CDN_EMAIL=
RUNTIME_CDN_DIR=
