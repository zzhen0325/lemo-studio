# Frontend -> Backend API base
# 默认指向本地 GuluX 服务的 /api 前缀
NEXT_PUBLIC_API_BASE=http://localhost:3000/api

# Dataset 存储后端选择
# - local: 使用本地文件系统 public/dataset（默认）
# - tos / s3: 预留给对象存储实现（当前为占位实现，调用会抛出 NotImplemented 错误）
CLOUD_STORAGE=local

# 对象公开访问前缀
# - 当使用本地存储时留空，将通过 Next 静态资源 `/dataset/...` 暴露
# - 当接入云存储（如 TOS/S3）时，设置为 CDN 或桶的公开域名前缀，例如：
#   CLOUD_PUBLIC_BASE=https://your-cdn-domain.com/dataset
CLOUD_PUBLIC_BASE=

# 覆盖默认本地 Dataset 目录（可选）
# 不设置时默认为 <project_root>/public/dataset
#DATASET_DIR=/data/lemon8/dataset

# 以下为未来接入 TOS 时预留的环境变量示例（当前代码仅有占位实现）
#TOS_ENDPOINT=
#TOS_BUCKET=
#TOS_ACCESS_KEY_ID=
#TOS_SECRET_ACCESS_KEY=
