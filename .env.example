# Next.js
# Recommended for split frontend/backend deployment:
# - GULUX_API_BASE is used by the Next.js server-side proxy and SSR requests.
# - NEXT_PUBLIC_API_BASE is used by browser-side direct requests when explicitly configured.
NEXT_PUBLIC_API_BASE=http://127.0.0.1:3000/api
GULUX_API_BASE=http://127.0.0.1:3000/api
NEXT_PUBLIC_COMFYUI_URL=
NEXT_PUBLIC_APP_PORT=3001
NEXT_PUBLIC_SIDEBAR_MODE=full
NEXT_IMAGE_ALLOWED_HOSTS=

# Gulux server
# Production deployment must provide a real Mongo URI instead of relying on local defaults.
MONGODB_URI=mongodb://127.0.0.1:27017/gulux
MONGODB_DB=gulux
API_CONFIG_ENCRYPTION_KEY=replace-with-a-strong-secret
CORS_ALLOW_ORIGINS=http://localhost:3001
COZE_PROMPT_API_TOKEN=
COZE_PROMPT_RUN_URL=https://m5385m4ryw.coze.site/run
COZE_SEED_API_TOKEN=
COZE_SEED_RUN_URL=https://2q3rqt6rnh.coze.site/run
