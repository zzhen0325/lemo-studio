# Lemon8 AI Studio 环境配置
# 使用扣子的 Supabase 数据库和对象存储

# 应用端口配置
NEXT_PUBLIC_APP_PORT=
PORT=
HOSTNAME=

# 前端配置
# NEXT_PUBLIC_API_BASE 留空时使用相对路径 /api
# NEXT_PUBLIC_COMFYUI_URL 配置内网 ComfyUI 地址，前端直连模式
NEXT_PUBLIC_API_BASE=
NEXT_PUBLIC_SIDEBAR_MODE=
NEXT_PUBLIC_COMFYUI_URL=
NEXT_DISABLE_IMAGE_OPTIMIZATION=
NEXT_PUBLIC_BASE_URL=

# ==========================================
# 扣子集成配置（自动从环境变量读取）
# ==========================================

# Supabase 数据库配置
# 以下环境变量由扣子平台自动注入，无需手动配置：
COZE_SUPABASE_URL=
COZE_SUPABASE_ANON_KEY=
COZE_WORKSPACE_PATH=
DEPLOY_RUN_PORT=
COZE_PROJECT_ENV=
COZE_PROJECT_DOMAIN_DEFAULT=

# 对象存储配置
# 以下环境变量由扣子平台自动注入，无需手动配置：
COZE_BUCKET_ENDPOINT_URL=
COZE_BUCKET_NAME=

DB_PASSWORD=
STORAGE_ACCESS_KEY=


FORNAX_AK=
FORNAX_SK=
FORNAX_REGION=
FORNAX_KV_PROMPT_KEY=
FORNAX_KV_USER_NAME=


# ==========================================
# AI 提供商配置（可选，根据需要填写）
# ==========================================

# 豆包/火山引擎
DOUBAO_API_KEY=
DOUBAO_BASE_URL=
DOUBAO_MODEL=

# Google AI
GOOGLE_API_KEY=
GOOGLE_GENAI_API_KEY=
GOOGLE_TRANSLATE_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Coze (改用 LEMO_ 前缀避免与平台变量冲突)
LEMO_COZE_API_TOKEN=
LEMO_COZE_PROMPT_API_TOKEN=
LEMO_COZE_PROMPT_RUN_URL=
LEMO_COZE_SEED_API_TOKEN=
LEMO_COZE_SEED_RUN_URL=
LEMO_COZE_EDIT_RUN_URL=
LEMO_COZE_EDIT_API_TOKEN=
# 字节跳动 AFR/Seed 图片生成
GATEWAY_BASE_URL=
BYTEDANCE_AID=
BYTEDANCE_APP_KEY=
BYTEDANCE_APP_SECRET=

# ComfyUI / ViewComfy
# COMFYUI_API_URL: 后端连接 ComfyUI 的地址（用于 /api/comfy-fluxklein 等后端代理路由）
# NEXT_PUBLIC_COMFYUI_URL: 前端直连 ComfyUI 的地址（用于浏览器直接连接）
COMFYUI_API_URL=
COMFYUI_SECURE=
VIEW_COMFY_FILE_NAME=
VIEWCOMFY_CLOUD_API_URL=
VIEWCOMFY_CLIENT_ID=
VIEWCOMFY_CLIENT_SECRET=
NEXT_PUBLIC_VIEWCOMFY_CLIENT_ID=
NEXT_PUBLIC_VIEWCOMFY_CLIENT_SECRET=

# 存储配置（已切换到扣子对象存储，无需配置）
CLOUD_STORAGE=
DATASET_DIR=
API_CONFIG_ENCRYPTION_KEY=
