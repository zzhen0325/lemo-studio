# Curated runtime env example for local development and single-service Next deployment.
# Keep secrets on the server. Do not expose secrets via NEXT_PUBLIC_*.

# Frontend / public runtime
# Leave empty to keep browser requests on same-origin /api.
# Only set when the browser must call a different public origin directly.
NEXT_PUBLIC_API_BASE=
NEXT_PUBLIC_APP_PORT=3001
NEXT_PUBLIC_SIDEBAR_MODE=full
NEXT_PUBLIC_COMFYUI_URL=
NEXT_DISABLE_IMAGE_OPTIMIZATION=true
NEXT_IMAGE_ALLOWED_HOSTS=
NEXT_PUBLIC_ENABLE_TWEAKCN_LIVE_PREVIEW=false

# Optional absolute site origin for backend-side image fetching.
NEXT_PUBLIC_BASE_URL=

# Server required
# Supabase database is auto-configured via COZE integration
API_CONFIG_ENCRYPTION_KEY=replace-with-a-strong-secret

# AI providers
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-1-6-251015

GOOGLE_API_KEY=
GOOGLE_GENAI_API_KEY=
GOOGLE_TRANSLATE_API_KEY=

DEEPSEEK_API_KEY=

LEMO_COZE_API_TOKEN=
LEMO_COZE_PROMPT_API_TOKEN=
LEMO_COZE_PROMPT_RUN_URL=https://m5385m4ryw.coze.site/run
LEMO_COZE_SEED_API_TOKEN=
LEMO_COZE_SEED_RUN_URL=https://2q3rqt6rnh.coze.site/run

# Fornax PTaaS (KV structured prompt optimization)
FORNAX_AK=
FORNAX_SK=
FORNAX_REGION=I18N
FORNAX_KV_PROMPT_KEY=lemon8.festa.image_generate_optimize
FORNAX_KV_USER_NAME=zz

# ByteDance AFR / Seed image generation
GATEWAY_BASE_URL=https://effect.bytedance.net
BYTEDANCE_AID=6834
BYTEDANCE_APP_KEY=
BYTEDANCE_APP_SECRET=

# ComfyUI and ViewComfy
COMFYUI_API_URL=
COMFYUI_SECURE=false
VIEW_COMFY_FILE_NAME=workflows/index.json
VIEWCOMFY_CLOUD_API_URL=
VIEWCOMFY_CLIENT_ID=
VIEWCOMFY_CLIENT_SECRET=
NEXT_PUBLIC_VIEWCOMFY_CLIENT_ID=
NEXT_PUBLIC_VIEWCOMFY_CLIENT_SECRET=

# Storage and CDN
DATASET_DIR=
CLOUD_STORAGE=local
CLOUD_PUBLIC_BASE=
CDN_BASE_URL=
CDN_DIR=
CDN_REGION=SG
CDN_EMAIL=
RUNTIME_CDN_DIR=
